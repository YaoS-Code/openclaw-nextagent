[Unit]
Description=OpenClaw Flask API
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/openclaw-services/backend
ExecStart=/usr/bin/python3 -m gunicorn -w 4 -b 127.0.0.1:4001 app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
