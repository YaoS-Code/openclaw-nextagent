[Unit]
Description=OpenClaw Memory Service (pgvector + bge-m3)
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/openclaw-memory-service
ExecStart=/home/YOUR_USER/openclaw-memory-service/venv/bin/uvicorn main:app --host 127.0.0.1 --port 18800
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
